#!/usr/bin/env bash

############################################################
# aws-ec2
#
# CLI tool for inspecting EC2 fleets
#
# Commands
#   aws-ec2 list
#   aws-ec2 audit
#   aws-ec2 images
#
############################################################


#################################
# Colors
#################################

GREEN="\033[32m"
RED="\033[31m"
BLUE="\033[34m"
YELLOW="\033[33m"
ORANGE="\033[38;5;208m"
RESET="\033[0m"


#################################
# Help
#################################

show_help() {

cat <<EOF

aws-ec2 - EC2 fleet inspection tool

Usage:
  aws-ec2 <command> [options]

Commands:

  list
      List EC2 instances across regions

  audit
      Show instance uptime and AMI details

  images
      Show AMIs used by instances

  help
      Show this help message

Examples:

  aws-ec2 list
  aws-ec2 audit
  aws-ec2 images

EOF

}


#################################
# Regions helper
#################################

get_regions() {

aws ec2 describe-regions \
--query "Regions[].RegionName" \
--output text

}


#################################
# LIST INSTANCES
#################################

cmd_list() {

printf "${ORANGE}%-15s %-20s %-20s %-10s %-10s${RESET}\n" \
"Region" "InstanceId" "Name" "Type" "State"

for r in $(get_regions); do

aws ec2 describe-instances --region "$r" \
--query "Reservations[].Instances[].[InstanceId,Tags[?Key=='Name']|[0].Value,InstanceType,State.Name]" \
--output text |

while read id name type state; do

if [ "$state" = "running" ]; then
color=$GREEN
else
color=$RED
fi

printf "${YELLOW}%-15s${RESET} %-20s %-20s %-10s ${color}%-10s${RESET}\n" \
"$r" "$id" "$name" "$type" "$state"

done

done

}


#################################
# AUDIT INSTANCES
#################################

cmd_audit() {

printf "${ORANGE}%-14s %-19s %-14s %-8s %-8s %-6s %-19s %-24s${RESET}\n" \
"Region" "InstanceId" "Name" "Type" "State" "Uptime" "AMI ID" "AMI Name"

for r in $(get_regions); do

declare -A ami_name_cache

aws ec2 describe-instances --region "$r" \
--query "Reservations[].Instances[].[InstanceId,Tags[?Key=='Name']|[0].Value,InstanceType,State.Name,ImageId,LaunchTime]" \
--output text |

while read id name type state image_id launch; do

if [ -z "${ami_name_cache[$image_id]+x}" ]; then
ami_name_cache[$image_id]=$(aws ec2 describe-images \
--region "$r" \
--image-ids "$image_id" \
--query "Images[0].Name" \
--output text)
fi

launch_epoch=$(date -d "$launch" +%s)
now_epoch=$(date +%s)

uptime_days=$(( (now_epoch - launch_epoch) / 86400 ))

printf "${YELLOW}%-14.14s${RESET} %-19.19s %-14.14s %-8.8s %-8.8s %-5sd %-19.19s %-24.24s\n" \
"$r" "$id" "$name" "$type" "$state" "$uptime_days" "$image_id" "${ami_name_cache[$image_id]}"

done

done

}


#################################
# LIST AMIS USED
#################################

cmd_images() {

printf "${ORANGE}%-15s %-20s %-45s${RESET}\n" \
"Region" "AMI ID" "AMI Name"

for r in $(get_regions); do

aws ec2 describe-instances --region "$r" \
--query "Reservations[].Instances[].ImageId" \
--output text |

for ami in $(cat); do

name=$(aws ec2 describe-images \
--region "$r" \
--image-ids "$ami" \
--query "Images[0].Name" \
--output text)

printf "${YELLOW}%-15s${RESET} %-20s %-45s\n" \
"$r" "$ami" "$name"

done

done

}


#################################
# Command dispatcher
#################################

case "$1" in

list)
cmd_list
;;

audit)
cmd_audit
;;

images)
cmd_images
;;

help|"")
show_help
;;

*)
echo "Unknown command: $1"
show_help
exit 1
;;

esac
